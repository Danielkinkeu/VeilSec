# IA Provider (gemini | groq | claude)
LLM_PROVIDER=gemini

# Gemini (gratuit par défaut)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (gratuit, alternatif)
GROQ_API_KEY=your_groq_api_key_here

# Claude (optionnel, payant)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Intervalles de collecte (en heures)
NVD_INTERVAL_HOURS=6
CISA_INTERVAL_HOURS=12
GITHUB_INTERVAL_HOURS=6
EXPLOITDB_INTERVAL_HOURS=2

# Base de données
DATABASE_URL=sqlite:///./veilsec.db
